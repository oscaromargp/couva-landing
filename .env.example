# ============================================================
# Variables de entorno — copia este archivo a .env y rellena.
# El .env real NUNCA se sube a git (ver .gitignore).
# ============================================================

# URL pública del sitio (para OG tags, canonical, sitemap). Sin slash final.
# GitHub Pages: https://oscaromargp.github.io  +  PUBLIC_BASE_PATH=/couva-landing
# Netlify/Cloudflare (dominio raíz): tu subdominio  +  PUBLIC_BASE_PATH=/
PUBLIC_SITE_URL=https://oscaromargp.github.io
PUBLIC_BASE_PATH=/couva-landing

# Endpoint del webhook de n8n que recibe los formularios (lead + referidos).
# Lo usa el navegador, por eso lleva prefijo PUBLIC_. Es una URL pública por diseño;
# la protección real (token/anti-spam) vive DENTRO del workflow de n8n.
PUBLIC_N8N_WEBHOOK_URL=https://n8n.zxyw.site/webhook/couva-lead

# Link público de agenda (Google Calendar appointment).
PUBLIC_CALENDAR_URL=https://calendar.app.google/T3QKi6h9VhtzSRDeA

# --- Marketing / medición (opcionales; el sitio los activa solo si existen) ---
# Google Analytics 4 (formato G-XXXXXXX)
PUBLIC_GA4_ID=
# Meta Pixel ID (número de ~15 dígitos). El token de CAPI va en n8n, NO aquí.
PUBLIC_META_PIXEL_ID=

# --- Supabase (claves públicas; el contador de visitas las usa en el navegador) ---
PUBLIC_SUPABASE_URL=https://aekdukfjftzbbrixuqbk.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable__QHR3TiiXE5i4ECjTMFkSA_uWrAV8F0
