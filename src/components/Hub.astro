---
import { content, contact, withBase, type Lang } from '../i18n/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const h = content[lang].hub;
const t = content[lang];
const modelos = content[lang].negocios.modelos;
const other = lang === 'es' ? 'en' : 'es';
const otherHref = withBase(`/${other}`);
const homeHref = withBase(`/${lang}`);
const m = (p: string) => withBase(p);
const waHref = `${contact.whatsapp}?text=${encodeURIComponent(lang === 'es' ? 'Hola, quiero información de PardeSantos.' : 'Hi, I want info about PardeSantos.')}`;
const icons: Record<string, string> = {
  chart: '<path d="M4 20V10M10 20V4M16 20v-7M22 20H2" stroke-linecap="round"/>',
  clock: '<path d="M12 7v5l3 2" stroke-linecap="round"/><circle cx="12" cy="12" r="9"/>',
  shield: '<path d="M12 3l7 3v6c0 4-3 7-7 9-4-2-7-5-7-9V6z"/>',
  bolt: '<path d="M13 2L4 14h6l-1 8 9-12h-6z" stroke-linejoin="round"/>',
};
---

<!-- NAV -->
<header class="bg-ink">
  <nav class="wrap flex items-center justify-between py-4">
    <a href={homeHref} class="flex items-center gap-2 font-display text-xl font-bold text-white">
      <svg width="26" height="26" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#C9A24B"/><path d="M32 14 L50 30 H44 V50 H36 V38 H28 V50 H20 V30 H14 Z" fill="#0B1F2A"/></svg>
      PardeSantos
    </a>
    <div class="flex items-center gap-3">
      <a href={otherHref} class="rounded-full border border-white/30 px-3 py-1.5 text-sm font-semibold text-white hover:bg-white/10">{t.langName}</a>
      <a href={waHref} target="_blank" rel="noopener" class="btn-gold !px-5 !py-2.5 text-sm">{t.contact.whatsapp}</a>
    </div>
  </nav>
</header>

<!-- HERO -->
<section class="bg-ink pb-14 pt-10 text-cream sm:pb-20">
  <div class="wrap">
    <p class="eyebrow reveal">{h.eyebrow}</p>
    <h1 class="reveal mt-4 max-w-3xl font-display text-4xl font-bold leading-[1.05] text-white sm:text-5xl md:text-6xl">{h.title}</h1>
    <p class="reveal mt-5 max-w-xl text-lg text-sand/85">{h.sub}</p>
  </div>
</section>

<!-- 3 PUERTAS -->
<section class="bg-cream py-16 sm:py-24">
  <div class="wrap grid gap-6 md:grid-cols-3">
    {h.doors.map((d) => (
      <a href={m(d.link)} class="reveal group flex flex-col overflow-hidden rounded-3xl bg-white shadow-soft ring-1 ring-ink/5 transition hover:-translate-y-1 hover:shadow-gold">
        <div class="relative aspect-[4/3] overflow-hidden">
          <img src={m(d.img)} alt={d.title} loading="lazy" class="h-full w-full object-cover transition group-hover:scale-105" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink/70 to-transparent"></div>
          <h2 class="absolute bottom-4 left-5 font-display text-2xl font-bold text-white">{d.title}</h2>
        </div>
        <div class="flex flex-1 flex-col p-6">
          <p class="flex-1 text-ink/70">{d.desc}</p>
          <span class="mt-4 inline-flex items-center gap-1 font-semibold text-golddk">{d.cta} →</span>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- MODELOS -->
<section class="bg-ink py-20 text-cream sm:py-28">
  <div class="wrap">
    <h2 class="reveal text-3xl font-bold sm:text-4xl">{h.modelosTitle}</h2>
    <p class="reveal mt-3 max-w-2xl text-lg text-sand/80">{h.modelosSub}</p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {modelos.map((mo) => (
        <a href={m('/es/' + mo.slug)} class="reveal group flex flex-col overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 transition hover:ring-gold/50">
          <img src={m(mo.img)} alt={mo.name} loading="lazy" class="aspect-[4/3] w-full object-cover transition group-hover:scale-[1.03]" />
          <div class="flex flex-1 flex-col p-4">
            <div class="text-xs font-bold uppercase tracking-wide text-sea">{mo.tag}</div>
            <div class="mt-1 flex items-baseline justify-between">
              <h3 class="font-bold text-white">{mo.name}</h3>
              <span class="font-display font-bold text-gold">{mo.price}</span>
            </div>
            <span class="mt-3 text-sm font-semibold text-gold underline">{content[lang].negocios.verFicha} →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- TRUST -->
<section class="bg-cream py-20 sm:py-28">
  <div class="wrap">
    <h2 class="reveal text-3xl font-bold sm:text-4xl">{h.trustTitle}</h2>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {h.trust.map((it) => (
        <div class="reveal card">
          <div class="mb-3 grid h-10 w-10 place-items-center rounded-xl bg-gold/15 text-golddk">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icons[it.icon]} />
          </div>
          <h3 class="font-bold">{it.title}</h3>
          <p class="mt-1 text-sm text-ink/70">{it.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-deep py-12 text-sand/70">
  <div class="wrap grid gap-8 md:grid-cols-2">
    <div>
      <div class="flex items-center gap-2 font-display text-lg font-bold text-white">
        <svg width="22" height="22" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#C9A24B"/><path d="M32 14 L50 30 H44 V50 H36 V38 H28 V50 H20 V30 H14 Z" fill="#0B1F2A"/></svg>
        PardeSantos
      </div>
      <p class="mt-3 max-w-sm text-sm">{t.footer.tagline}</p>
      <p class="mt-3 text-sm">{t.contact.name} · {contact.phone} · {contact.email}</p>
    </div>
    <div class="md:text-right">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm md:justify-end">
        <a href={m(`/${lang}/couva`)} class="hover:text-gold">{lang === 'es' ? 'Residencial' : 'Residential'}</a>
        <a href={m(lang === 'es' ? '/es/negocios' : '/en/business')} class="hover:text-gold">{lang === 'es' ? 'Comercial' : 'Commercial'}</a>
        <a href={m(lang === 'es' ? '/es/socios' : '/en/partners')} class="hover:text-gold">{lang === 'es' ? 'Socios' : 'Partners'}</a>
        <a href={m(`/${lang}/${lang === 'es' ? 'aviso-de-privacidad' : 'privacy'}`)} class="hover:text-gold">{t.footer.privacy}</a>
      </div>
    </div>
  </div>
</footer>
