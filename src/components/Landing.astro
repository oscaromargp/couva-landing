<script define:vars={{ WEBHOOK, lang, okMsg: t.leadForm.ok, errMsg: t.leadForm.err, sending: t.leadForm.sending }}>
  // --- Nav solidify on scroll ---
  const nav = document.getElementById('nav');
  const onScroll = () => {
    if (window.scrollY > 40) nav.classList.add('bg-ink/95','backdrop-blur','shadow-soft');
    else nav.classList.remove('bg-ink/95','backdrop-blur','shadow-soft');
  };
  onScroll(); window.addEventListener('scroll', onScroll, { passive: true });

  // --- Reveal on scroll ---
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  // --- ROI calculator ---
  const fmt = new Intl.NumberFormat(lang === 'es' ? 'es-MX' : 'en-US', { style: 'currency', currency: 'MXN', maximumFractionDigits: 0 });
  const $ = (id) => document.getElementById(id);
  function calcRoi() {
    const rate = +$('roi-rate').value || 0;
    const occ = (+$('roi-occ').value || 0) / 100;
    const fx = +$('roi-fx').value || 0;
    const months = +$('roi-months').value || 0;
    const monthly = rate * 30 * occ * fx;
    $('roi-monthly').textContent = fmt.format(monthly);
    $('roi-saved').textContent = fmt.format(monthly * months);
  }
  ['roi-rate','roi-occ','roi-fx','roi-months'].forEach((id) => $(id)?.addEventListener('input', calcRoi));
  calcRoi();

  // --- UTM capture ---
  const params = new URLSearchParams(location.search);
  const utm = {
    utm_source: params.get('utm_source') || '',
    utm_medium: params.get('utm_medium') || '',
    utm_campaign: params.get('utm_campaign') || '',
    utm_content: params.get('utm_content') || '',
    utm_term: params.get('utm_term') || '',
    referrer: document.referrer || '',
    landing_path: location.pathname,
  };

  // --- Conversión (Meta Pixel + GA4). No-op si no hay píxel/analytics. ---
  const META_EVENT = { lead: 'Lead', referral: 'Lead', configurador: 'Lead', descarga: 'CompleteRegistration' };
  function trackConversion(formType, eventId) {
    try {
      if (window.fbq) fbq('track', META_EVENT[formType] || 'Lead', { content_name: 'COUVA 6x6', content_category: formType }, { eventID: eventId });
      if (window.gtag) {
        gtag('event', 'generate_lead', { method: formType, event_id: eventId });
        if (formType === 'descarga') gtag('event', 'file_download', { file_name: 'catalogo-couva-pardesantos.pdf' });
      }
    } catch (e) {}
  }
  const newId = () => (self.crypto && crypto.randomUUID) ? crypto.randomUUID() : String(Date.now()) + '-' + Math.random().toString(16).slice(2);

  // --- Form submit (lead + referral) ---
  function bindForm(id, formType) {
    const form = document.getElementById(id);
    if (!form) return;
    const status = form.querySelector('.form-status');
    const btn = form.querySelector('button[type=submit]');
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (form.company && form.company.value) return; // honeypot
      const data = Object.fromEntries(new FormData(form).entries());
      data.consentimiento = !!form.querySelector('[name=consentimiento]')?.checked;
      const eventId = newId();
      const payload = { form: formType, idioma: lang, event_id: eventId, ...utm, ...data, ts: new Date().toISOString() };
      const original = btn.textContent;
      btn.disabled = true; btn.textContent = sending; status.textContent = '';
      try {
        const res = await fetch(WEBHOOK, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        if (!res.ok) throw new Error(res.status);
        trackConversion(formType, eventId);
        status.style.color = '#0F7A4F'; status.textContent = form.dataset.successMsg || okMsg; form.reset();
        // Descarga gateada: al enviar, dispara el PDF
        if (form.dataset.download) {
          const a = document.createElement('a');
          a.href = form.dataset.download; a.setAttribute('download', ''); a.target = '_blank';
          document.body.appendChild(a); a.click(); a.remove();
        }
      } catch (err) {
        status.style.color = '#B4442E'; status.textContent = errMsg;
      } finally {
        btn.disabled = false; btn.textContent = original;
      }
    });
  }
  bindForm('lead-form', 'lead');
  bindForm('referral-form', 'referral');
  bindForm('configurador-form', 'configurador');
  bindForm('descarga-form', 'descarga');

  // --- Galería con pestañas ---
  const tabs = document.querySelectorAll('.gal-tab');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const key = tab.getAttribute('data-tab');
      tabs.forEach((t2) => {
        const active = t2 === tab;
        t2.setAttribute('aria-selected', active ? 'true' : 'false');
        t2.classList.toggle('bg-ink', active);
        t2.classList.toggle('text-cream', active);
        t2.classList.toggle('bg-white', !active);
        t2.classList.toggle('text-ink', !active);
        t2.classList.toggle('ring-1', !active);
        t2.classList.toggle('ring-ink/10', !active);
      });
      document.querySelectorAll('.gal-panel').forEach((p) => {
        p.style.display = p.getAttribute('data-panel') === key ? 'grid' : 'none';
      });
    });
  });

  // --- Modal de descarga ---
  const modal = document.getElementById('download-modal');
  const openModal = () => { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; };
  const closeModal = () => { modal.style.display = 'none'; document.body.style.overflow = ''; };
  document.querySelectorAll('[data-open-download]').forEach((b) => b.addEventListener('click', openModal));
  document.querySelectorAll('[data-close-download]').forEach((b) => b.addEventListener('click', closeModal));
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
