---
import { content, contact, withBase, type Lang } from '../i18n/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = content[lang];
const other = lang === 'es' ? 'en' : 'es';

const WEBHOOK = import.meta.env.PUBLIC_N8N_WEBHOOK_URL || 'https://n8n.zxyw.site/webhook/couva-lead';
const CAL = contact.calendar;
const homeHref = withBase(`/${lang}`);
const otherHref = withBase(`/${other}`);
const privacyHref = withBase(lang === 'es' ? `/${lang}/aviso-de-privacidad` : `/${lang}/privacy`);
const termsHref = withBase(lang === 'es' ? `/${lang}/terminos` : `/${lang}/terms`);
const refTermsHref = withBase(lang === 'es' ? `/${lang}/terminos-referidos` : `/${lang}/referral-terms`);
const m = (p: string) => withBase(p); // helper corto para medios
const waMsg = lang === 'es'
  ? 'Hola, vi la COUVA 6×6 y quiero más información y cotización.'
  : 'Hi, I saw the COUVA 6×6 and would like more info and a quote.';
const waHref = `${contact.whatsapp}?text=${encodeURIComponent(waMsg)}`;

const icons: Record<string, string> = {
  clock: '<path d="M12 7v5l3 2" stroke-linecap="round"/><circle cx="12" cy="12" r="9"/>',
  chart: '<path d="M4 20V10M10 20V4M16 20v-7M22 20H2" stroke-linecap="round"/>',
  shield: '<path d="M12 3l7 3v6c0 4-3 7-7 9-4-2-7-5-7-9V6z"/>',
  wave: '<path d="M2 12c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2 2-2 4-2" stroke-linecap="round"/><path d="M2 17c2 0 2-2 4-2s2 2 4 2 2-2 4-2 2 2 4 2 2-2 4-2" stroke-linecap="round"/>',
  bolt: '<path d="M13 2L4 14h6l-1 8 9-12h-6z" stroke-linejoin="round"/>',
  drop: '<path d="M12 3s6 6 6 10a6 6 0 01-12 0c0-4 6-10 6-10z" stroke-linejoin="round"/>',
  pipe: '<path d="M4 8h8a4 4 0 014 4v8M4 5v6M20 17v4" stroke-linecap="round"/>',
  bath: '<path d="M4 12h16v3a4 4 0 01-4 4H8a4 4 0 01-4-4z"/><path d="M6 12V6a2 2 0 012-2 2 2 0 012 2" stroke-linecap="round"/>',
  kitchen: '<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M8 3v6M4 9h16" stroke-linecap="round"/>',
  sofa: '<path d="M4 11V8a2 2 0 012-2h12a2 2 0 012 2v3"/><path d="M2 13a2 2 0 012-2 2 2 0 012 2v3h12v-3a2 2 0 012-2 2 2 0 012 2v5H2z"/>',
  wind: '<path d="M3 8h10a3 3 0 10-3-3M3 12h14a3 3 0 11-3 3M3 16h8a2 2 0 11-2 2" stroke-linecap="round"/>',
  quake: '<path d="M2 12h3l2-6 4 12 3-9 2 3h6" stroke-linecap="round" stroke-linejoin="round"/>',
  salt: '<circle cx="12" cy="12" r="9"/><path d="M8 10c1 1 2 1 3 0M13 10c1 1 2 1 3 0M8 15h8" stroke-linecap="round"/>',
};
---

<!-- NAV -->
<header id="nav" class="fixed inset-x-0 top-0 z-50 transition-all duration-300">
  <nav class="wrap flex items-center justify-between py-4">
    <a href={homeHref} class="flex items-center gap-2 font-display text-xl font-bold text-white">
      <svg width="26" height="26" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#C9A24B"/><path d="M32 14 L50 30 H44 V50 H36 V38 H28 V50 H20 V30 H14 Z" fill="#0B1F2A"/></svg>
      PardeSantos
    </a>
    <div class="hidden items-center gap-7 text-sm font-medium text-white/90 lg:flex">
      <a href="#pain" class="hover:text-gold">{t.nav.pain}</a>
      <a href="#solution" class="hover:text-gold">{t.nav.solution}</a>
      <a href="#roi" class="hover:text-gold">{t.nav.roi}</a>
      <a href="#specs" class="hover:text-gold">{t.nav.specs}</a>
      <a href="#referral" class="hover:text-gold">{t.nav.referral}</a>
    </div>
    <div class="flex items-center gap-3">
      <a href={otherHref} class="rounded-full border border-white/30 px-3 py-1.5 text-sm font-semibold text-white hover:bg-white/10">{t.langName}</a>
      <a href="#contact" class="btn-gold !px-5 !py-2.5 text-sm">{t.nav.cta}</a>
    </div>
  </nav>
</header>

<!-- HERO -->
<section class="relative flex min-h-[92vh] items-center overflow-hidden bg-ink">
  <video class="absolute inset-0 h-full w-full object-cover opacity-45" autoplay muted loop playsinline poster={m('/media/exterior-frontal.jpeg')}>
    <source src={m('/media/casa-1.mp4')} type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/85 to-ink/40"></div>
  <div class="wrap relative z-10 pt-28">
    <p class="eyebrow reveal">{t.hero.eyebrow}</p>
    <h1 class="reveal mt-4 max-w-3xl text-4xl font-bold leading-[1.05] text-white sm:text-5xl md:text-6xl">
      {t.hero.title}<br /><span class="text-gold">{t.hero.titleAccent}</span>
    </h1>
    <p class="reveal mt-6 max-w-xl text-lg text-sand/90">{t.hero.sub}</p>
    <div class="reveal mt-8 flex flex-wrap gap-4">
      <a href={CAL} target="_blank" rel="noopener" class="btn-gold">{t.hero.cta1}</a>
      <a href="#specs" class="btn-ghost">{t.hero.cta2}</a>
    </div>
    <div class="reveal mt-12 flex flex-wrap gap-x-10 gap-y-6 border-t border-white/15 pt-8">
      {[['stat1n','stat1l'],['stat2n','stat2l'],['stat3n','stat3l']].map(([n,l])=> (
        <div>
          <div class="font-display text-3xl font-bold text-gold">{(t.hero as any)[n]}</div>
          <div class="text-sm text-sand/70">{(t.hero as any)[l]}</div>
        </div>
      ))}
    </div>
    <p class="reveal mt-8 text-sm text-white/50">{t.hero.trust}</p>
  </div>
</section>

<!-- MARQUESINA de beneficios -->
<div class="overflow-hidden border-y border-gold/20 bg-ink py-3">
  <div class="marquee flex w-max whitespace-nowrap">
    {[...t.marquee, ...t.marquee].map((b) => (
      <span class="mx-5 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-gold">
        <span class="text-gold/50">◆</span> {b}
      </span>
    ))}
  </div>
</div>

<!-- PAIN -->
<section id="pain" class="bg-cream py-20 sm:py-28">
  <div class="wrap">
    <h2 class="reveal max-w-2xl text-3xl font-bold sm:text-4xl">{t.pain.title}</h2>
    <p class="reveal mt-4 max-w-2xl text-lg text-ink/70">{t.pain.sub}</p>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {t.pain.items.map((it)=> (
        <div class="reveal card">
          <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-sea/10 text-sea">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icons[it.icon]} />
          </div>
          <h3 class="text-lg font-bold">{it.title}</h3>
          <p class="mt-2 text-ink/70">{it.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SOLUTION -->
<section id="solution" class="bg-ink py-20 text-cream sm:py-28">
  <div class="wrap grid items-center gap-12 lg:grid-cols-2">
    <div>
      <p class="eyebrow reveal">PardeSantos · COUVA 6×6</p>
      <h2 class="reveal mt-3 text-3xl font-bold sm:text-4xl">{t.solution.title}</h2>
      <p class="reveal mt-4 text-lg text-sand/80">{t.solution.sub}</p>
      <div class="mt-8 space-y-6">
        {t.solution.points.map((p)=> (
          <div class="reveal flex gap-4">
            <div class="mt-1 grid h-7 w-7 shrink-0 place-items-center rounded-full bg-gold text-ink">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L20 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-white">{p.title}</h3>
              <p class="mt-1 text-sand/75">{p.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="reveal">
      <img src={m('/media/interior.jpeg')} alt={t.meta.ogAlt} loading="lazy" class="aspect-[4/3] w-full rounded-3xl object-cover shadow-soft ring-1 ring-white/10" />
    </div>
  </div>
</section>

<!-- YA VIENE LISTA (ingenierías incluidas) -->
<section class="bg-cream py-20 sm:py-28">
  <div class="wrap">
    <p class="eyebrow reveal">{t.incluye.eyebrow}</p>
    <h2 class="reveal mt-3 max-w-2xl text-3xl font-bold sm:text-4xl">{t.incluye.title}</h2>
    <p class="reveal mt-4 max-w-2xl text-lg text-ink/70">{t.incluye.sub}</p>
    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {t.incluye.items.map((it) => (
        <div class="reveal card flex gap-4">
          <div class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-sea/10 text-sea">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icons[it.icon]} />
          </div>
          <div>
            <h3 class="font-bold">{it.title}</h3>
            <p class="mt-1 text-sm text-ink/70">{it.body}</p>
          </div>
        </div>
      ))}
    </div>
    <p class="reveal mt-6 inline-flex items-center gap-2 rounded-full bg-sea/10 px-4 py-2 text-sm font-medium text-sea">✅ {t.incluye.note}</p>
  </div>
</section>

<!-- CONFORT TÉRMICO + OFF-GRID -->
<section class="bg-ink py-20 text-cream sm:py-28">
  <div class="wrap grid gap-12 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="eyebrow reveal">{t.confort.eyebrow}</p>
      <h2 class="reveal mt-3 text-3xl font-bold sm:text-4xl">{t.confort.title}</h2>
      <p class="reveal mt-4 text-lg text-sand/80">{t.confort.sub}</p>
      <div class="mt-8 space-y-4">
        {t.confort.points.map((p) => (
          <div class="reveal flex items-center gap-5 rounded-2xl bg-white/5 p-4 ring-1 ring-white/10">
            <div class="w-28 shrink-0 font-display text-2xl font-bold text-gold">{p.stat}</div>
            <div class="text-sm text-sand/85">{p.label}</div>
          </div>
        ))}
      </div>
      <p class="reveal mt-4 text-xs text-sand/50">{t.confort.note}</p>
    </div>
    <div class="reveal grid grid-cols-2 gap-4">
      <div class="rounded-2xl bg-gradient-to-b from-orange-500/25 to-orange-800/10 p-6 text-center ring-1 ring-orange-400/20">
        <div class="text-5xl">🥵</div>
        <div class="mt-3 text-xs uppercase tracking-widest text-sand/60">{lang === 'es' ? 'Afuera' : 'Outside'}</div>
        <div class="font-display text-xl font-bold text-white">{lang === 'es' ? 'Sol y bochorno' : 'Heat & humidity'}</div>
      </div>
      <div class="rounded-2xl bg-gradient-to-b from-sea/40 to-aqua/10 p-6 text-center ring-1 ring-aqua/30">
        <div class="text-5xl">😎</div>
        <div class="mt-3 text-xs uppercase tracking-widest text-sand/60">{lang === 'es' ? 'Adentro' : 'Inside'}</div>
        <div class="font-display text-xl font-bold text-white">{lang === 'es' ? 'Fresco y seco' : 'Cool & dry'}</div>
      </div>
    </div>
  </div>
</section>

<!-- RESISTENCIA Y CLIMA COSTERO -->
<section class="bg-cream py-20 sm:py-28">
  <div class="wrap">
    <p class="eyebrow reveal">{t.resistencia.eyebrow}</p>
    <h2 class="reveal mt-3 max-w-2xl text-3xl font-bold sm:text-4xl">{t.resistencia.title}</h2>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {t.resistencia.items.map((it) => (
        <div class="reveal card border-t-4 border-sea">
          <div class="grid h-12 w-12 place-items-center rounded-xl bg-sea/10 text-sea">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" set:html={icons[it.icon]} />
          </div>
          <h3 class="mt-4 text-lg font-bold">{it.title}</h3>
          <p class="mt-2 text-ink/70">{it.body}</p>
        </div>
      ))}
    </div>
    <p class="reveal mt-6 text-sm text-ink/50">⚠️ {t.resistencia.note}</p>
  </div>
</section>

<!-- MANTENIMIENTO HONESTO -->
<section class="bg-deep py-20 text-cream sm:py-28">
  <div class="wrap">
    <p class="eyebrow reveal">{t.mantenimiento.eyebrow}</p>
    <h2 class="reveal mt-3 max-w-2xl text-3xl font-bold sm:text-4xl">{t.mantenimiento.title}</h2>
    <p class="reveal mt-4 max-w-2xl text-lg text-sand/80">{t.mantenimiento.sub}</p>
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {t.mantenimiento.rows.map(([k, v]) => (
        <div class="reveal rounded-2xl bg-white/5 p-5 ring-1 ring-white/10">
          <div class="font-bold text-gold">{k}</div>
          <p class="mt-1 text-sand/80">{v}</p>
        </div>
      ))}
    </div>
    <p class="reveal mt-6 inline-flex items-center gap-2 rounded-full bg-gold/15 px-4 py-2 text-sm font-medium text-gold">💰 {t.mantenimiento.note}</p>
  </div>
</section>

<!-- ARGS -->
<section class="bg-cream py-20 sm:py-28">
  <div class="wrap">
    <h2 class="reveal max-w-3xl text-3xl font-bold sm:text-4xl">{t.args.title}</h2>
    <p class="reveal mt-4 max-w-2xl text-lg text-ink/70">{t.args.sub}</p>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {t.args.list.map((a)=> (
        <div class="reveal card border-t-4 border-gold">
          <div class="font-display text-4xl font-bold text-gold/40">{a.n}</div>
          <h3 class="mt-2 text-xl font-bold">{a.title}</h3>
          <p class="mt-2 text-ink/70">{a.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- COMPARATIVA DE VALOR REAL -->
<section id="comparativa" class="bg-cream pb-20 sm:pb-28">
  <div class="wrap">
    <p class="eyebrow reveal">{t.compare.eyebrow}</p>
    <h2 class="reveal mt-3 max-w-3xl text-3xl font-bold sm:text-4xl">{t.compare.title}</h2>
    <p class="reveal mt-4 max-w-2xl text-lg text-ink/70">{t.compare.sub}</p>

    <!-- Tabla (desktop) -->
    <div class="reveal mt-10 hidden overflow-hidden rounded-2xl shadow-soft ring-1 ring-ink/5 md:block">
      <table class="w-full border-collapse text-left text-sm">
        <thead>
          <tr class="bg-ink text-cream">
            <th class="p-4 font-semibold">{t.compare.col1}</th>
            <th class="p-4 font-bold text-gold">{t.compare.winner}</th>
            <th class="p-4 font-semibold text-sand/80">{t.compare.rest1}</th>
            <th class="p-4 font-semibold text-sand/80">{t.compare.rest2}</th>
          </tr>
        </thead>
        <tbody>
          {t.compare.rows.map((r, i) => (
            <tr class={i % 2 ? 'bg-white' : 'bg-sand/20'}>
              <td class="p-4 font-semibold text-ink">{r.c}</td>
              <td class="border-l-4 border-gold bg-gold/5 p-4 font-medium text-ink">{r.a}</td>
              <td class="p-4 text-ink/60">{r.b}</td>
              <td class="p-4 text-ink/60">{r.d}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Tarjetas (móvil) -->
    <div class="mt-8 space-y-4 md:hidden">
      {t.compare.rows.map((r) => (
        <div class="reveal card">
          <div class="text-xs font-bold uppercase tracking-wide text-sea">{r.c}</div>
          <div class="mt-3 rounded-xl border-l-4 border-gold bg-gold/5 p-3">
            <div class="text-xs font-semibold text-gold">{t.compare.winner}</div>
            <div class="font-medium text-ink">{r.a}</div>
          </div>
          <div class="mt-2 grid grid-cols-1 gap-2 text-sm">
            <div class="rounded-lg bg-cream p-3"><span class="block text-xs text-ink/50">{t.compare.rest1}</span>{r.b}</div>
            <div class="rounded-lg bg-cream p-3"><span class="block text-xs text-ink/50">{t.compare.rest2}</span>{r.d}</div>
          </div>
        </div>
      ))}
    </div>
    <p class="reveal mt-4 text-xs text-ink/50">{t.compare.note}</p>
  </div>
</section>

<!-- ROI CALCULATOR -->
<section id="roi" class="bg-deep py-20 text-cream sm:py-28">
  <div class="wrap grid gap-10 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="eyebrow reveal">ROI</p>
      <h2 class="reveal mt-3 text-3xl font-bold sm:text-4xl">{t.roi.title}</h2>
      <p class="reveal mt-4 text-lg text-sand/80">{t.roi.sub}</p>
      <form id="roi-form" class="reveal mt-8 grid grid-cols-2 gap-4">
        <label class="text-sm">{t.roi.f_rate}
          <input type="number" id="roi-rate" value="65" min="0" class="field mt-1 !text-ink" />
        </label>
        <label class="text-sm">{t.roi.f_occ}
          <input type="number" id="roi-occ" value="70" min="0" max="100" class="field mt-1 !text-ink" />
        </label>
        <label class="text-sm">{t.roi.f_fx}
          <input type="number" id="roi-fx" value="17.5" min="0" step="0.1" class="field mt-1 !text-ink" />
        </label>
        <label class="text-sm">{t.roi.f_months}
          <input type="number" id="roi-months" value="8" min="0" max="24" class="field mt-1 !text-ink" />
        </label>
      </form>
    </div>
    <div class="reveal rounded-3xl bg-ink p-8 ring-1 ring-white/10">
      <div class="border-b border-white/10 pb-6">
        <div class="text-sm text-sand/70">{t.roi.out_month}</div>
        <div id="roi-monthly" class="font-display text-4xl font-bold text-gold">—</div>
      </div>
      <div class="pt-6">
        <div class="text-sm text-sand/70">{t.roi.out_saved}</div>
        <div id="roi-saved" class="font-display text-5xl font-bold text-white">—</div>
      </div>
      <p class="mt-6 text-xs leading-relaxed text-sand/50">{t.roi.note}</p>
      <a href="#lead" class="btn-gold mt-6 w-full">{t.roi.cta}</a>
    </div>
  </div>
</section>

<!-- SPECS -->
<section id="specs" class="bg-cream py-20 sm:py-28">
  <div class="wrap grid gap-10 lg:grid-cols-2">
    <div>
      <h2 class="reveal text-3xl font-bold sm:text-4xl">{t.specs.title}</h2>
      <dl class="reveal mt-8 divide-y divide-ink/10 rounded-2xl bg-white shadow-soft ring-1 ring-ink/5">
        {t.specs.rows.map(([k,v])=> (
          <div class="flex justify-between gap-4 px-5 py-3.5">
            <dt class="text-ink/60">{k}</dt>
            <dd class="text-right font-semibold">{v}</dd>
          </div>
        ))}
      </dl>
      <p class="reveal mt-4 text-sm text-ink/60">{t.specs.note}</p>
      <button type="button" class="btn-dark reveal mt-6" data-open-download>{t.specs.dl}</button>
    </div>
    <div class="reveal">
      <img src={m('/media/plano.jpg')} alt="Plano COUVA 6×6" loading="lazy" class="w-full rounded-3xl bg-white object-contain p-4 shadow-soft ring-1 ring-ink/5" />
    </div>
  </div>
</section>

<!-- GALLERY (pestañas: amueblada / obra / instalada) -->
<section id="galeria" class="bg-cream pb-20 sm:pb-28">
  <div class="wrap">
    <h2 class="reveal text-3xl font-bold sm:text-4xl">{t.gallery.title}</h2>
    <p class="reveal mt-3 text-lg text-ink/70">{t.gallery.sub}</p>

    <div class="reveal mt-8 flex flex-wrap gap-2" role="tablist">
      {[['amueblada', t.gallery.tabAmueblada], ['obra', t.gallery.tabObra], ['instalada', t.gallery.tabInstalada]].map(([key, label], i) => (
        <button type="button" class:list={["gal-tab rounded-full px-5 py-2 text-sm font-semibold transition", i === 0 ? "bg-ink text-cream" : "bg-white text-ink ring-1 ring-ink/10 hover:bg-sand/40"]} data-tab={key} aria-selected={i === 0 ? 'true' : 'false'}>{label}</button>
      ))}
    </div>

    <div class="gal-panel mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-panel="amueblada">
      {t.gallery.amueblada.map((g) => (<img src={m(g.src)} alt={g.alt} loading="lazy" class="aspect-[4/3] w-full rounded-2xl object-cover shadow-soft ring-1 ring-ink/5" />))}
    </div>
    <div class="gal-panel mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-panel="obra" style="display:none">
      {t.gallery.obra.map((g) => (<img src={m(g.src)} alt={g.alt} loading="lazy" class="aspect-[4/3] w-full rounded-2xl object-cover shadow-soft ring-1 ring-ink/5" />))}
    </div>
    <div class="gal-panel mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-panel="instalada" style="display:none">
      {t.gallery.instalada.map((g) => (<img src={m(g.src)} alt={g.alt} loading="lazy" class="aspect-[4/3] w-full rounded-2xl object-cover shadow-soft ring-1 ring-ink/5" />))}
    </div>

    <h3 class="reveal mt-12 text-xl font-bold">{t.gallery.videosTitle}</h3>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      {t.gallery.videos.map((v) => (
        <figure class="reveal">
          <video class="w-full rounded-2xl shadow-soft" controls preload="none" poster={m(v.poster)}><source src={m(v.src)} type="video/mp4" /></video>
