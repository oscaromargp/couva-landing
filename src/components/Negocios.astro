---
import { content, contact, withBase, type Lang } from '../i18n/content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const n = content[lang].negocios;
const tg = content[lang];
const other = lang === 'es' ? 'en' : 'es';
const otherHref = withBase(lang === 'es' ? '/en/business' : '/es/negocios');
const homeHref = withBase(`/${lang}`);
const sociosHref = withBase(lang === 'es' ? '/es/socios' : '/en/partners');
const privacyHref = withBase(lang === 'es' ? '/es/aviso-de-privacidad' : '/en/privacy');
const termsHref = withBase(lang === 'es' ? '/es/terminos' : '/en/terms');
const WEBHOOK = import.meta.env.PUBLIC_N8N_WEBHOOK_URL || 'https://n8n.zxyw.site/webhook/couva-lead';
const m = (p: string) => withBase(p);
const waHref = `${contact.whatsapp}?text=${encodeURIComponent(lang === 'es' ? 'Hola, me interesa cotizar un proyecto (línea comercial PardeSantos).' : 'Hi, I want to quote a project (PardeSantos commercial line).')}`;

const icons: Record<string, string> = {
  chart: '<path d="M4 20V10M10 20V4M16 20v-7M22 20H2" stroke-linecap="round"/>',
  clock: '<path d="M12 7v5l3 2" stroke-linecap="round"/><circle cx="12" cy="12" r="9"/>',
  shield: '<path d="M12 3l7 3v6c0 4-3 7-7 9-4-2-7-5-7-9V6z"/>',
  bolt: '<path d="M13 2L4 14h6l-1 8 9-12h-6z" stroke-linejoin="round"/>',
  sofa: '<path d="M4 11V8a2 2 0 012-2h12a2 2 0 012 2v3"/><path d="M2 13a2 2 0 012-2 2 2 0 012 2v3h12v-3a2 2 0 012-2 2 2 0 012 2v5H2z"/>',
  quake: '<path d="M2 12h3l2-6 4 12 3-9 2 3h6" stroke-linecap="round" stroke-linejoin="round"/>',
  kitchen: '<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M8 3v6M4 9h16" stroke-linecap="round"/>',
};
---

<!-- NAV -->
<header class="bg-ink">
  <nav class="wrap flex items-center justify-between py-4">
    <a href={homeHref} class="flex items-center gap-2 font-display text-xl font-bold text-white">
      <svg width="26" height="26" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#C9A24B"/><path d="M32 14 L50 30 H44 V50 H36 V38 H28 V50 H20 V30 H14 Z" fill="#0B1F2A"/></svg>
      PardeSantos
    </a>
    <div class="flex items-center gap-3">
      <a href={homeHref} class="hidden text-sm text-sand/80 hover:text-gold sm:block">{n.backHome}</a>
      <a href={otherHref} class="rounded-full border border-white/30 px-3 py-1.5 text-sm font-semibold text-white hover:bg-white/10">{tg.langName}</a>
      <a href="#cotizar" class="btn-gold !px-5 !py-2.5 text-sm">{n.cta}</a>
    </div>
  </nav>
</header>

<!-- HERO -->
<section class="bg-ink pb-16 pt-8 text-cream sm:pb-24">
  <div class="wrap">
    <p class="eyebrow reveal">{n.eyebrow}</p>
    <h1 class="reveal mt-4 max-w-3xl text-4xl font-bold leading-[1.05] sm:text-5xl md:text-6xl">
      {n.title} <span class="text-gold">{n.titleAccent}</span>
    </h1>
    <p class="reveal mt-6 max-w-2xl text-lg text-sand/85">{n.sub}</p>
    <div class="reveal mt-8 flex flex-wrap gap-4">
      <a href="#cotizar" class="btn-gold">{n.cta}</a>
      <a href="#modelos" class="btn-ghost">{n.cta2}</a>
    </div>
    <div class="reveal mt-12 grid gap-6 border-t border-white/15 pt-8 sm:grid-cols-3">
      {[['stat1n','stat1l'],['stat2n','stat2l'],['stat3n','stat3l']].map(([a,b])=> (
        <div>
          <div class="font-display text-3xl font-bold text-gold">{(n as any)[a]}</div>
          <div class="mt-1 text-sm text-sand/70">{(n as any)[b]}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CASOS DE USO -->
<section class="bg-cream py-20 sm:py-28">
  <div class="wrap">
    <h2 class="reveal max-w-2xl text-3xl font-bold sm:text-4xl">{n.usosTitle}</h2>
    <p class="reveal mt-3 max-w-2xl text-lg text-ink/70">{n.usosSub}</p>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {n.usos.map((u)=> (
        <div class="reveal card">
          <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-sea/10 text-sea">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icons[u.icon]} />
          </div>
          <h3 class="text-lg font-bold">{u.title}</h3>
          <p class="mt-2 text-sm text-ink/70">{u.body}</p>
          <div class="mt-3 inline-block rounded-full bg-ink px-3 py-1 text-xs font-bold text-gold">{u.modelo}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- COMPARADOR DE MODELOS -->
<section id="modelos" class="bg-ink py-20 text-cream sm:py-28">
  <div class="wrap">
    <h2 class="reveal max-w-2xl text-3xl font-bold sm:text-4xl">{n.modelosTitle}</h2>
    <p class="reveal mt-3 max-w-2xl text-lg text-sand/80">{n.modelosSub}</p>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {n.modelos.map((mo)=> (
        <a href={m('/es/' + mo.slug)} class="reveal group flex flex-col overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 transition hover:ring-gold/50">
          <img src={m(mo.img)} alt={mo.name} loading="lazy" class="aspect-[4/3] w-full object-cover transition group-hover:scale-[1.03]" />
          <div class="flex flex-1 flex-col p-5">
            <div class="text-xs font-bold uppercase tracking-wide text-sea">{mo.tag}</div>
            <div class="mt-1 flex items-baseline justify-between">
              <h3 class="text-xl font-bold text-white">{mo.name}</h3>
              <span class="font-display text-xl font-bold text-gold">{mo.price}</span>
            </div>
            <ul class="mt-3 flex-1 space-y-1.5 text-sm text-sand/80">
              {mo.feat.map((f)=> (
                <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-gold"></span>{f}</li>
              ))}
            </ul>
            <span class="mt-4 inline-block text-sm font-semibold text-gold underline">{n.verFicha} →</span>
          </div>
        </a>
      ))}
    </div>
    <p class="reveal mt-6 text-sm text-sand/50">*Precios por unidad, + envío. Descuento por volumen en cotización.</p>
  </div>
</section>

<!-- HOOKS B2B -->
<section class="bg-cream py-20 sm:py-28">
  <div class="wrap">
    <h2 class="reveal max-w-2xl text-3xl font-bold sm:text-4xl">{n.hooksTitle}</h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {n.hooks.map((h)=> (
        <div class="reveal card">
          <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-gold/15 text-golddk">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icons[h.icon]} />
          </div>
          <h3 class="text-lg font-bold">{h.title}</h3>
          <p class="mt-2 text-sm text-ink/70">{h.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- COTIZAR -->
<section id="cotizar" class="bg-deep py-20 text-cream sm:py-28">
  <div class="wrap grid gap-10 lg:grid-cols-2 lg:items-center">
    <div>
      <h2 class="reveal text-3xl font-bold sm:text-4xl">{n.formTitle}</h2>
      <p class="reveal mt-4 text-lg text-sand/80">{n.formSub}</p>
      <div class="reveal mt-6 flex flex-wrap gap-3">
        <a href={waHref} target="_blank" rel="noopener" class="btn-ghost">{tg.contact.whatsapp}</a>
        <a href={`mailto:${contact.email}`} class="btn-ghost">{tg.contact.email}</a>
      </div>
      <p class="reveal mt-6 text-sm text-sand/60">{tg.contact.name} · {contact.phone} · {contact.email}</p>
    </div>
    <div class="reveal card text-ink">
      <form id="negocios-form" class="space-y-4">
        <input type="text" name="company" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />
        <div><label class="label">{tg.leadForm.f_name}</label><input required name="nombre" class="field" /></div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div><label class="label">{tg.leadForm.f_phone}</label><input required name="telefono" class="field" /></div>
          <div><label class="label">{tg.leadForm.f_email}</label><input required type="email" name="email" class="field" /></div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div><label class="label">{n.f_modelo}</label>
            <select name="modelo" class="field">{n.modeloOpts.map((o)=> (<option value={o}>{o}</option>))}</select>
          </div>
          <div><label class="label">{n.f_unidades}</label>
            <select name="unidades" class="field">{n.unidadesOpts.map((o)=> (<option value={o}>{o}</option>))}</select>
          </div>
        </div>
        <div><label class="label">{n.f_uso}</label>
          <select name="uso_comercial" class="field">{n.usoOpts.map((o)=> (<option value={o}>{o}</option>))}</select>
        </div>
        <div><label class="label">{tg.leadForm.f_msg}</label><textarea name="mensaje" rows="2" class="field"></textarea></div>
        <label class="flex items-start gap-2 text-sm text-ink/70">
          <input required type="checkbox" name="consentimiento" class="mt-1" />
          <span>{tg.leadForm.consent} <a href={privacyHref} class="underline">{tg.footer.privacy}</a></span>
        </label>
        <button type="submit" class="btn-gold w-full">{n.submit}</button>
        <p class="form-status text-sm"></p>
      </form>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="bg-ink py-10 text-sand/70">
  <div class="wrap flex flex-wrap items-center justify-between gap-4 text-sm">
    <span>© {new Date().getFullYear()} PardeSantos · {tg.footer.rights}</span>
    <div class="flex flex-wrap gap-x-5 gap-y-1">
      <a href={homeHref} class="hover:text-gold">{n.backHome}</a>
      <a href={sociosHref} class="hover:text-gold">{lang === 'es' ? 'Programa de socios' : 'Partner program'}</a>
      <a href={privacyHref} class="hover:text-gold">{tg.footer.privacy}</a>
      <a href={termsHref} class="hover:text-gold">{tg.footer.terms}</a>
    </div>
  </div>
</footer>

<script define:vars={{ WEBHOOK, lang, okMsg: content[lang].leadForm.ok, errMsg: content[lang].leadForm.err, sending: content[lang].leadForm.sending }}>
  const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }), { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  const params = new URLSearchParams(location.search);
  const utm = { utm_source: params.get('utm_source') || '', utm_medium: params.get('utm_medium') || '', utm_campaign: params.get('utm_campaign') || '', referrer: document.referrer || '', landing_path: location.pathname };
  let ref = params.get('ref'); if (ref) { try { localStorage.setItem('couva_ref', ref); } catch (e) {} } else { try { ref = localStorage.getItem('couva_ref'); } catch (e) { ref = null; } }

  const form = document.getElementById('negocios-form');
  const status = form.querySelector('.form-status');
  const btn = form.querySelector('button[type=submit]');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (form.company.value) return;
    const data = Object.fromEntries(new FormData(form).entries());
    data.consentimiento = !!form.querySelector('[name=consentimiento]').checked;
    const payload = { form: 'negocios', idioma: lang, ref_codigo: ref || null, ...utm, ...data, ts: new Date().toISOString() };
    const orig = btn.textContent; btn.disabled = true; btn.textContent = sending; status.textContent = '';
    try {
      await window.couvaSubmit(payload);
      status.style.color = '#0F7A4F'; status.textContent = okMsg; form.reset();
    } catch (err) { status.style.color = '#B4442E'; status.textContent = errMsg; }
    finally { btn.disabled = false; btn.textContent = orig; }
  });
</script>
