---
import '../styles/global.css';
import { content, contact, withBase, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
  path?: string;        // ruta relativa sin idioma, ej. '' | '/aviso-de-privacidad'
  title?: string;
  description?: string;
  canonicalSlug?: string; // ruta absoluta propia (ej. '/es/socios'); si se pasa, se usa como canonical y se omiten alternates
}

const { lang, path = '', title, description, canonicalSlug } = Astro.props;
const t = content[lang];
// Analítica / píxeles (se activan solos cuando defines las variables de entorno)
const GA4_ID = import.meta.env.PUBLIC_GA4_ID;
const META_PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID;
// Contador propio de visitas (Supabase, insert público). Claves públicas por diseño.
const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'https://aekdukfjftzbbrixuqbk.supabase.co';
const SB_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'sb_publishable__QHR3TiiXE5i4ECjTMFkSA_uWrAV8F0';
// site + base de despliegue (para URLs absolutas de OG/canonical/sitemap)
const origin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const site = (origin + withBase('')).replace(/\/$/, '');

const pageTitle = title ?? t.meta.title;
const pageDesc = description ?? t.meta.description;

const urlEs = `${site}/es${path}`;
const urlEn = `${site}/en${path}`;
const canonical = canonicalSlug ? `${site}${canonicalSlug}` : (lang === 'es' ? urlEs : urlEn);
const ogImage = `${site}/og/og-${lang}.jpg`;

// JSON-LD: producto inmobiliario
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'COUVA 6×6 — PardeSantos',
  image: [`${site}/media/render-couva.png`, ogImage],
  description: pageDesc,
  brand: { '@type': 'Brand', name: 'PardeSantos' },
  category: lang === 'es' ? 'Casa modular prefabricada' : 'Prefab modular home',
  offers: {
    '@type': 'Offer',
    price: '495000',
    priceCurrency: 'MXN',
    availability: 'https://schema.org/InStock',
    url: canonical,
    seller: { '@type': 'Person', name: contact.name, email: contact.email, telephone: contact.phoneIntl },
  },
  areaServed: 'Puerto Escondido, Oaxaca, MX',
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="es" href={urlEs} />
    <link rel="alternate" hreflang="en" href={urlEn} />
    <link rel="alternate" hreflang="x-default" href={urlEs} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PardeSantos · COUVA 6×6" />
    <meta property="og:locale" content={t.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.meta.ogAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0B1F2A" />
    <meta name="robots" content="index, follow" />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {GA4_ID && (
      <Fragment>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
        <script is:inline define:vars={{ GA4_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){ dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA4_ID);
        </script>
      </Fragment>
    )}

    {META_PIXEL_ID && (
      <script is:inline define:vars={{ META_PIXEL_ID }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', META_PIXEL_ID);
        fbq('track', 'PageView');
      </script>
    )}
  </head>
  <body class="bg-cream text-ink antialiased selection:bg-gold/30">
    <slot />
    <script is:inline src={withBase('/couva-forms.js')}></script>
    {SB_URL && SB_ANON && (
      <script is:inline define:vars={{ SB_URL, SB_ANON }}>
        try {
          var h = location.hostname;
          if (!location.pathname.includes('/admin') && h !== 'localhost' && h !== '127.0.0.1') {
            const p = new URLSearchParams(location.search);
            fetch(SB_URL + '/rest/v1/visitas', {
              method: 'POST', keepalive: true,
              headers: { apikey: SB_ANON, Authorization: 'Bearer ' + SB_ANON, 'Content-Type': 'application/json', Prefer: 'return=minimal' },
              body: JSON.stringify({ path: location.pathname, idioma: document.documentElement.lang, referrer: document.referrer || null, utm_source: p.get('utm_source'), utm_campaign: p.get('utm_campaign'), ua: navigator.userAgent.slice(0, 120) }),
            }).catch(function(){});
          }
        } catch (e) {}
      </script>
    )}
  </body>
</html>
