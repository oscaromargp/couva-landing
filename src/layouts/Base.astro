---
import '../styles/global.css';
import { content, contact, withBase, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
  path?: string;        // ruta relativa sin idioma, ej. '' | '/aviso-de-privacidad'
  title?: string;
  description?: string;
}

const { lang, path = '', title, description } = Astro.props;
const t = content[lang];
// site + base de despliegue (para URLs absolutas de OG/canonical/sitemap)
const origin = Astro.site?.toString().replace(/\/$/, '') ?? '';
const site = (origin + withBase('')).replace(/\/$/, '');

const pageTitle = title ?? t.meta.title;
const pageDesc = description ?? t.meta.description;

const urlEs = `${site}/es${path}`;
const urlEn = `${site}/en${path}`;
const canonical = lang === 'es' ? urlEs : urlEn;
const ogImage = `${site}/og/og-${lang}.jpg`;

// JSON-LD: producto inmobiliario
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'COUVA 6×6 — PardeSantos',
  image: [`${site}/media/render-couva.png`, ogImage],
  description: pageDesc,
  brand: { '@type': 'Brand', name: 'PardeSantos' },
  category: lang === 'es' ? 'Casa modular prefabricada' : 'Prefab modular home',
  offers: {
    '@type': 'Offer',
    price: '495000',
    priceCurrency: 'MXN',
    availability: 'https://schema.org/InStock',
    url: canonical,
    seller: { '@type': 'Person', name: contact.name, email: contact.email, telephone: contact.phoneIntl },
  },
  areaServed: 'Puerto Escondido, Oaxaca, MX',
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="es" href={urlEs} />
    <link rel="alternate" hreflang="en" href={urlEn} />
    <link rel="alternate" hreflang="x-default" href={urlEs} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PardeSantos · COUVA 6×6" />
    <meta property="og:locale" content={t.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.meta.ogAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0B1F2A" />
    <meta name="robots" content="index, follow" />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-cream text-ink antialiased selection:bg-gold/30">
    <slot />
  </body>
</html>
