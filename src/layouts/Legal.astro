---
import Base from './Base.astro';
import { content, contact, type Lang } from '../i18n/content';

interface Props { lang: Lang; path: string; title: string; updated: string; }
const { lang, path, title, updated } = Astro.props;
const t = content[lang];
const backLabel = lang === 'es' ? '← Volver al inicio' : '← Back to home';
const updLabel = lang === 'es' ? 'Última actualización' : 'Last updated';
---
<Base lang={lang} path={path} title={`${title} · PardeSantos`} description={title}>
  <header class="bg-ink py-5">
    <div class="wrap flex items-center justify-between">
      <a href={`/${lang}`} class="flex items-center gap-2 font-display text-lg font-bold text-white">
        <svg width="22" height="22" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#C9A24B"/><path d="M32 14 L50 30 H44 V50 H36 V38 H28 V50 H20 V30 H14 Z" fill="#0B1F2A"/></svg>
        PardeSantos
      </a>
      <a href={`/${lang}`} class="text-sm text-sand/80 hover:text-gold">{backLabel}</a>
    </div>
  </header>
  <main class="wrap py-14">
    <h1 class="text-3xl font-bold sm:text-4xl">{title}</h1>
    <p class="mt-2 text-sm text-ink/50">{updLabel}: {updated}</p>
    <article class="legal mt-8 max-w-3xl">
      <slot />
    </article>
  </main>
  <footer class="border-t border-ink/10 py-8">
    <div class="wrap text-sm text-ink/60">
      {contact.name} · {contact.email} · {contact.phone}
    </div>
  </footer>
</Base>

<style is:global>
  .legal h2 { @apply mt-8 mb-2 text-xl font-bold; }
  .legal h3 { @apply mt-5 mb-1 text-base font-bold; }
  .legal p, .legal li { @apply text-ink/80 leading-relaxed; }
  .legal p { @apply mt-3; }
  .legal ul { @apply mt-3 list-disc space-y-1 pl-6; }
  .legal a { @apply text-sea underline; }
  .legal strong { @apply text-ink; }
</style>
